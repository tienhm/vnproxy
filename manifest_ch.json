{
  "manifest_version": 3,
  "name": "VN Proxy Manager",
  "version": "1.0.2",
  "description": "Automatically purchase, renew, and apply proxy for selected sites",

  "permissions": [
    "proxy",
    "storage",
    "notifications",
    "webRequest",
    "webRequestAuthProvider",
    "declarativeNetRequest"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background_chrome.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VN Proxy Manager",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },

  "web_accessible_resources": [{
    "resources": ["error.html", "error.js", "polyfill.js"],
    "matches": ["<all_urls>"]
  }]
}
