{
  "manifest_version": 2,
  "name": "VN Proxy Manager",
  "version": "1.0.2",
  "description": "Automatically purchase, renew, and apply proxy for selected sites",

  "permissions": [
    "proxy",
    "storage",
    "notifications",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["polyfill.js", "background_chrome.js"],
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "VN Proxy Manager",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },

  "web_accessible_resources": ["error.html"]
}
